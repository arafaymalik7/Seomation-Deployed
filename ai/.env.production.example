# Runtime
LOG_LEVEL=info
CACHE_TTL_SECONDS=21600

# LLM providers
GEMINI_API_KEY=<gemini-api-key>
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GROQ_API_KEY=<groq-api-key>
GROQ_MODEL=llama-3.3-70b-versatile

# Search providers
SERPAPI_KEY=<serpapi-key>
SERPER_API_KEY=<serper-api-key-or-empty>
GN_HL=en-PK
GN_GL=PK
GN_CEID=PK:en

# Embeddings and vector memory
EMBEDDER=cohere
COHERE_API_KEY=<cohere-api-key>
SBERT_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_BACKEND=qdrant
QDRANT_URL=https://<qdrant-cluster-url>
QDRANT_API_KEY=<qdrant-api-key>
QDRANT_COLLECTION=seomation_prod

# Optional pgvector fallback. Leave blank when VECTOR_BACKEND=qdrant.
DATABASE_URL=
PGVECTOR_DIM=1024

# Image generation providers. Configure at least one real provider before placeholder.
IMAGE_PROVIDER_ORDER=kie,huggingface,together,placeholder
KIE_API_KEY=<kie-api-key-or-empty>
KIE_MODEL=seedream/4.5-text-to-image
KIE_GUIDANCE_SCALE=2.5
KIE_CREATE_TIMEOUT_SECONDS=25
KIE_POLL_DELAY_SECONDS=3
KIE_POLL_TIMEOUT_SECONDS=120
KIE_POLL_REQUEST_TIMEOUT_SECONDS=15
TOGETHER_API_KEY=<together-api-key-or-empty>
TOGETHER_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
TOGETHER_IMAGE_STEPS=4
TOGETHER_IMAGE_TIMEOUT_SECONDS=45
HUGGINGFACE_API_KEY=<huggingface-api-key-or-empty>
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
HUGGINGFACE_IMAGE_STEPS=25
HUGGINGFACE_IMAGE_TIMEOUT_SECONDS=90
