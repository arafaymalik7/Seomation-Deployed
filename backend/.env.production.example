# Core runtime
NODE_ENV=production
NODE_VERSION=20
PORT=3000

# Database
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>?schema=public

# Frontend/backend public URLs
APP_BASE_URL=https://<frontend-domain>
INTEGRATION_CALLBACK_BASE=https://<backend-service-domain>
CORS_ALLOWED_ORIGINS=https://<frontend-domain>

# Auth and token security
JWT_ACCESS_SECRET=<generate-a-long-random-secret>
JWT_REFRESH_SECRET=<generate-a-different-long-random-secret>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
INTEGRATION_STATE_SECRET=<generate-a-different-long-random-secret>
INTEGRATION_TOKEN_ENCRYPTION_KEY=<32-plus-char-secret-or-64-hex-or-base64-32-byte-key>

# AI service
AI_SERVICE_URL=https://<ai-service-domain>
AI_MOCK=false
AI_TOPIC_TIMEOUT_MS=60000
AI_CONTENT_TIMEOUT_MS=360000
AI_IMAGE_TIMEOUT_MS=450000
AI_SEO_TIMEOUT_MS=30000

# Persistent media storage
PUBLIC_ASSET_BASE_URL=https://<backend-service-domain>
ASSET_PUBLIC_PATH=/media
ASSET_STORAGE_DIR=/opt/render/project/src/storage/media
ASSET_CACHE_MAX_AGE=365d
JSON_BODY_LIMIT=15mb

# WordPress OAuth
WP_AUTH_URL=https://public-api.wordpress.com/oauth2/authorize
WP_CLIENT_ID=<wordpress-client-id>
WP_CLIENT_SECRET=<wordpress-client-secret>
WP_REDIRECT_URI=https://<backend-service-domain>/api/integrations/wordpress/callback
WP_SCOPE=global

# LinkedIn OAuth
LI_AUTH_URL=https://www.linkedin.com/oauth/v2/authorization
LI_CLIENT_ID=<linkedin-client-id>
LI_CLIENT_SECRET=<linkedin-client-secret>
LI_REDIRECT_URI=https://<backend-service-domain>/api/integrations/linkedin/callback
LI_SCOPE=openid profile email w_member_social

# Instagram / Meta OAuth
ENABLE_INSTAGRAM_INTEGRATION=false
IG_AUTH_URL=https://www.facebook.com/v21.0/dialog/oauth
IG_CLIENT_ID=<meta-app-id>
IG_CLIENT_SECRET=<meta-app-secret>
IG_REDIRECT_URI=https://<backend-service-domain>/api/integrations/instagram/callback
IG_SCOPE=pages_show_list,pages_read_engagement,instagram_basic,instagram_content_publish,business_management
IG_GRAPH_VERSION=v21.0
